# ─────────────────────────────────────────────────────────────
# Eternime — environment variables
# Copy to .env.local and fill in. In production these live in Vercel.
# When keys are absent the app falls back to demo/no-op behavior.
# ─────────────────────────────────────────────────────────────

# Database (Neon — control plane = `main` branch)
DATABASE_URL=                      # Pooled connection (app traffic)
DATABASE_URL_UNPOOLED=             # Direct connection (migrations/DDL)
NEON_PROJECT_ID=small-scene-28669707
NEON_API_KEY=                      # Used to create a branch per user

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional: dedicated key to encrypt tenant DB URLs.
# If unset, derives from CLERK_SECRET_KEY (per-user salted, AES-256-GCM).
TENANT_URL_ENCRYPTION_KEY=

# AI (Google Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=                    # alias

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Voice (ElevenLabs)
ELEVENLABS_API_KEY=
XI_API_KEY=                        # alias

# Emails (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Eternime <hola@eternime.org>

# Branding
NEXT_PUBLIC_APP_URL=https://eternime.org
NEXT_PUBLIC_BRAND_NAME=Eternime
